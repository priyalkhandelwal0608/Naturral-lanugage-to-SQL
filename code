# ==============================
# IMPORTS (UPDATED)
# ==============================
import pandas as pd
from sqlalchemy import create_engine
from langchain_community.utilities import SQLDatabase
from langchain_experimental.sql import SQLDatabaseChain
from langchain_ollama import OllamaLLM   # ✅ NEW IMPORT

# ==============================
# CREATE DATABASE
# ==============================
data = {
    "Name": ["Alice", "Bob", "Charlie", "David"],
    "Age": [25, 30, 35, 40],
    "Salary": [50000, 60000, 70000, 80000]
}

df = pd.DataFrame(data)

engine = create_engine("sqlite:///example.db")
df.to_sql("employees", engine, index=False, if_exists="replace")

print("✅ Database ready!")

# ==============================
# CONNECT DATABASE
# ==============================
db = SQLDatabase.from_uri("sqlite:///example.db")
print("📊 Tables:", db.get_usable_table_names())

# ==============================
# LOAD OLLAMA MODEL (NEW WAY)
# ==============================
llm = OllamaLLM(model="llama3")

# ==============================
# CREATE SQL CHAIN (FIXED)
# ==============================
db_chain = SQLDatabaseChain.from_llm(llm, db, verbose=True)

# ==============================
# RUN QUERY
# ==============================
response = db_chain.run("What is the average salary?")
print("\n📊 Answer:", response)
